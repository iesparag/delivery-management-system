generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SuperAdmin {
  id        Int    @id @default(autoincrement())
  email     String @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Tenant {
  id        Int    @id @default(autoincrement())
  name      String @unique
  users     User[]
  tasks     Task[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
}

model User {
  id        Int    @id @default(autoincrement())
  tenantId  Int
  email     String @unique
  role      Role
  tasks     Task[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
  
  Tenant    Tenant @relation(fields: [tenantId], references: [id])
}

model Task {
  id        Int    @id @default(autoincrement())
  tenantId  Int
  userId    Int?
  description String
  status    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
  
  Tenant    Tenant @relation(fields: [tenantId], references: [id])
  User      User?  @relation(fields: [userId], references: [id])
}

model Role {
  id    Int    @id @default(autoincrement())
  name  String @unique
}
